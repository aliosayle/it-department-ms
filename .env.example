# Copy to .env.local (gitignored) for local Vite. The SPA is locked: you must set an API URL and sign in.

# REST API base (include /api/v1). With Vite dev server, /api/v1 uses vite.config.ts proxy to port 4000.
VITE_API_BASE_URL=/api/v1

# Optional: commercial DevExtreme key; omit for evaluation key.
# VITE_DEVEXTREME_LICENSE_KEY=

# VITE_ENABLE_EVAL_WATERMARK_MITIGATION=false
