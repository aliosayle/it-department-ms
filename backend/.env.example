PORT=4000
NODE_ENV=development

# MariaDB (match scripts/setup-ubuntu.sh output or .credentials-mariadb.env)
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=it_department
DATABASE_USER=it_department_app
DATABASE_PASSWORD=changeme

JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Comma-separated origins for CORS (SPA dev server), or * to reflect the request Origin (typical behind nginx)
CORS_ORIGIN=http://localhost:5173

# Required for `npm run seed` (single superadmin user; truncates app tables)
# SEED_SUPERADMIN_LOGIN=superadmin
# SEED_SUPERADMIN_PASSWORD=
